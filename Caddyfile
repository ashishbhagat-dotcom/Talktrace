151.185.42.194.nip.io {
    encode gzip
    reverse_proxy frontend:80 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For {remote_host}
        header_up Host {host}
    }
}

# Also serve on the bare IP for fallback (Caddy uses a self-signed cert here)
:443 {
    encode gzip
    reverse_proxy frontend:80 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For {remote_host}
        header_up Host {host}
    }
}
