# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=conv_intel
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/conv_intel

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MinIO (S3-compatible object storage for audio/files) ────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=conversations
USE_MINIO=True

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# Set LLM_PROVIDER=openai for development (lower RAM usage)
# Set LLM_PROVIDER=ollama for production/staging with GPU/high-RAM server
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Set WHISPER_MODEL=base for dev (fast, low RAM), large-v3 for prod (accurate)
WHISPER_MODEL=base

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ─── Email (password reset) ───────────────────────────────────────────────────
# Use console backend in development (prints emails to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@talktrace.io

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_LIFETIME=60
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_LIFETIME=7

# ─── Zoho CRM (Phase 3 — leave empty until Phase 3) ─────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_URL=https://www.zohoapis.com/crm/v2
